# Backend database
DATABASE_URL=jdbc:postgresql://localhost:5432/ecommerce_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me-locally

# Backend security (must be Base64 encoded for JwtService)
JWT_SECRET=replace-with-a-long-random-base64-secret
JWT_EXPIRATION=3600000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Backend runtime
PORT=8080
JPA_DDL_AUTO=update
SQL_INIT_MODE=always
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
